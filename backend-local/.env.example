# ===========================================
# Tshwane BusNav Backend - Local Development
# ===========================================
# Copy this file to .env and update the values
#
# cp .env.example .env
#
# Then update DATABASE_URL with your local PostgreSQL credentials
# ===========================================

# PostgreSQL Database Connection
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/busnav"

# JWT Secret for authentication (change this to a random string)
JWT_SECRET="your-secret-key-change-me-in-production"
